{
  // ═══════════════════════════════════════════════════════════════════════════
  // APPEARANCE (keeping your preferences)
  // ═══════════════════════════════════════════════════════════════════════════
  "theme": {
    "mode": "system",
    "light": "Dayfox - blurred",
    "dark": "Ayu Dark"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Light Charmed Icons",
    "dark": "Catppuccin Mocha"
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_family": "JetBrainsMono Nerd Font",
  "buffer_line_height": {
    "custom": 1.5
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // EDITOR
  // ═══════════════════════════════════════════════════════════════════════════
  "vim_mode": true,
  "relative_line_numbers": true,
  "cursor_blink": false,
  "preferred_line_length": 100,
  "soft_wrap": "preferred_line_length",
  "tab_size": 2,
  "hard_tabs": false,
  "use_smartcase_search": true,
  "search": {
    "whole_word": false,
    "case_sensitive": false,
    "regex": false
  },

  // Autosave
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },

  // File handling
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",

  // Scrollbar
  "scrollbar": {
    "show": "auto",
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "diagnostics": true
  },

  // Indent guides
  "indent_guides": {
    "enabled": true,
    "background_coloring": "indent_aware",
    "coloring": "indent_aware"
  },

  // Sticky scroll
  "sticky_scroll": {
    "enabled": true,
    "max_lines": 4
  },

  // Inlay hints
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": false,
    "show_other_hints": true
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // GIT
  // ═══════════════════════════════════════════════════════════════════════════
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "position": "right"
    }
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // TABS & PANELS
  // ═══════════════════════════════════════════════════════════════════════════
  "tabs": {
    "show_icons": true,
    "git_status": true,
    "close_position": "right",
    "show_diagnostics": "errors"
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false
  },
  "project_panel": {
    "button": true,
    "dock": "left",
    "default_width": 240,
    "git_status": true,
    "indent_size": 16,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true
  },
  "outline_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "notification_panel": {
    "dock": "right"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // WINDOW
  // ═══════════════════════════════════════════════════════════════════════════
  "window_decorations": "client",
  "title_bar": {
    "show_menus": true,
    "show_branch_icon": true,
    "show_project_name": true,
    "show_branch_name": true
  },
  "centered_layout": {
    "left_padding": 0.12,
    "right_padding": 0.12
  },
  "file_finder": {
    "modal_max_width": "medium"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // TERMINAL
  // ═══════════════════════════════════════════════════════════════════════════
  "terminal": {
    "shell": {
      "program": "fish"
    },
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 14,
    "copy_on_select": true,
    "env": {
      "EDITOR": "zed --wait"
    }
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // LANGUAGES
  // ═══════════════════════════════════════════════════════════════════════════
  "languages": {
    "TypeScript": {
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_other_hints": true,
        "show_type_hints": true
      }
    },
    "JavaScript": {
      "inlay_hints": {
        "enabled": true
      }
    },
    "Python": {
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "ruff"
        }
      },
      "language_servers": ["pyright", "ruff"]
    },
    "Rust": {
      "format_on_save": "on",
      "inlay_hints": {
        "enabled": true,
        "show_type_hints": true,
        "show_parameter_hints": true
      }
    },
    "Go": {
      "format_on_save": "on"
    },
    "Ruby": {
      "format_on_save": "on",
      "language_servers": ["ruby-lsp"]
    }
  },
// ═══════════════════════════════════════════════════════════════════════════
// LSP
// ═══════════════════════════════════════════════════════════════════════════
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classAttributes": ["class", "className", "ngClass", "styles"]
      }
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy"
        },
        "inlayHints": {
          "bindingModeHints": {
            "enable": true
          },
          "closureReturnTypeHints": {
            "enable": "always"
          }
        },
        "completion": {
          "autoimport": {
            "enable": true
          }
        },
        "procMacro": {
          "enable": true
        },
        "cargo": {
          "allFeatures": true
        }
      }
    },
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": true,
          "formatting": true,
          "codeActions": true,
          "completion": true,
          "hover": true,
          "inlayHint": true
        }
      }
    }
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // FILE HANDLING
  // ═══════════════════════════════════════════════════════════════════════════
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"]
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules",
    "**/target",
    "**/dist",
    "**/build",
    "**/.next",
    "**/.nuxt",
    "**/.venv",
    "**/venv",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.turbo",
    "**/.vscode"
  ],

  // ═══════════════════════════════════════════════════════════════════════════
  // AI ASSISTANT
  // ═══════════════════════════════════════════════════════════════════════════
  "assistant": {
    "version": "2",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-20250514"
    }
  },
  "features": {
    "edit_prediction_provider": "zed"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // PRIVACY & SESSION
  // ═══════════════════════════════════════════════════════════════════════════
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "redact_private_values": true
}
