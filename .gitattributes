# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Explicitly set line endings for specific file types
*.sh text eol=lf
*.fish text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
